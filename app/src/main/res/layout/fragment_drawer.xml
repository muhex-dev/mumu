<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Container for Drawer Content -->
    <LinearLayout
        android:id="@+id/drawerCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="14dp"
        android:background="@drawable/bg_drawer"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search Header (Top) -->
        <LinearLayout
            android:id="@+id/searchHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:layout_marginHorizontal="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@android:color/transparent">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchViewApps"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search"
                android:elevation="8dp"
                app:iconifiedByDefault="false"
                app:queryHint="Search Apps"
                app:queryBackground="@android:color/transparent" />

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_search"
                android:contentDescription="Menu"
                android:elevation="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Recycler View (Below Search) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/appRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

    <com.example.myapplication.MuhexScroller
        android:id="@+id/muhexScroller"
        android:layout_width="150dp"
        android:layout_height="0dp"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/letterPreviewBubble"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:gravity="center"
        android:textSize="32sp"
        android:textColor="@color/onSurface"
        android:background="@drawable/bg_bubble_glass"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Drawer Settings Overlay (Compose) -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/drawerSettingsCompose"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>