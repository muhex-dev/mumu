<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Top Time & Date -->
    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:format12Hour="hh:mm a"
            android:format24Hour="HH:mm"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:format12Hour="dd MMMM"
            android:format24Hour="dd MMMM"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/batteryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:text="BATTERY --%"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:alpha="0.6"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Main Message -->
    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topInfo">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="HAVE"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="A "
                android:textColor="@android:color/white"
                android:textSize="36sp"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:fontFamily="sans-serif-black"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="NICE"
                android:textColor="@android:color/black"
                android:textSize="36sp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:includeFontPadding="false" />

    </LinearLayout>

    <!-- Divider Line -->
    <View
        android:id="@+id/greetingDivider"
        android:layout_width="80dp"
        android:layout_height="6dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/messageContainer" />

    <!-- Bottom Inspiration/Quotes Placeholder -->
    <TextView
        android:id="@+id/quoteText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:alpha="0.7"
        android:fontFamily="sans-serif"
        android:text="STAY INSPIRED\nBelieve in yourself and all that you are. Know that there is something inside you that is greater than any obstacle."
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/greetingDivider" />

</androidx.constraintlayout.widget.ConstraintLayout>