<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/stackContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

         <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:format12Hour="hh"
            android:format24Hour="HH"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:textColor="@android:color/white"
            android:textSize="72sp" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:format12Hour="mm"
            android:format24Hour="mm"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:textColor="@android:color/white"
            android:textSize="72sp"
            android:layout_marginTop="-12dp" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="2dp"
        android:layout_height="120dp"
        android:layout_marginStart="24dp"
        android:background="@android:color/white"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="@id/stackContainer"
        app:layout_constraintStart_toEndOf="@id/stackContainer"
        app:layout_constraintTop_toTopOf="@id/stackContainer" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/divider"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintTop_toTopOf="@id/divider">

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:letterSpacing="0.2" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:format12Hour="MMM dd"
            android:format24Hour="MMM dd"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:alpha="0.7" />

        <TextView
            android:id="@+id/batteryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:text="--%"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/quoteText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-italic"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:alpha="0.6"
            android:text="STAY INSPIRED" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>