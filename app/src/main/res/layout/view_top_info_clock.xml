<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextClock
        android:id="@+id/bigClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        android:textColor="@android:color/white"
        android:textSize="80sp"
        android:letterSpacing="-0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/batteryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:text="SYSTEM STATUS: NOMINAL"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:alpha="0.6"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="@id/bigClock"
        app:layout_constraintTop_toBottomOf="@id/bigClock" />

    <TextView
        android:id="@+id/batteryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:text="BATTERY: --%"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:alpha="0.6"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="@id/bigClock"
        app:layout_constraintTop_toBottomOf="@id/batteryLabel" />

    <View
        android:id="@+id/accentLine"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/white"
        app:layout_constraintStart_toStartOf="@id/bigClock"
        app:layout_constraintTop_toBottomOf="@id/batteryText" />

    <TextClock
        android:id="@+id/dateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif"
        android:format12Hour="EEEE, MMMM dd"
        android:format24Hour="EEEE, MMMM dd"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@id/bigClock"
        app:layout_constraintTop_toBottomOf="@id/accentLine" />

    <TextView
        android:id="@+id/quoteText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif-italic"
        android:text="STAY INSPIRED"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:alpha="0.6"
        app:layout_constraintStart_toStartOf="@id/bigClock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateLabel" />

</androidx.constraintlayout.widget.ConstraintLayout>